# ============================================================
# ShadowMind — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env
#
# NEVER commit the .env file to git — it has your real secrets.
# This .env.example file is safe to commit because it has no real keys.
# ============================================================

# Groq API key — get it from: https://console.groq.com → API Keys → Create
# Free tier: 30 requests/minute, 6000 tokens/minute
GROQ_API_KEY=your_groq_api_key_here

# Cohere API key — get it from: https://dashboard.cohere.com/api-keys
# Free tier: 1000 RPM, industry-leading embeddings.
COHERE_API_KEY=your_cohere_api_key_here

# Qdrant Cloud Cluster — get it from: https://cloud.qdrant.io/
# Free tier: 1 cluster, 1GB storage (plenty for our evidence).
QDRANT_URL=your_qdrant_cluster_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# Tavily API key — get it from: https://app.tavily.com/
# Free tier: 1000 searches/month. Used as a fallback when Qdrant evidence is weak.
TAVILY_API_KEY=your_tavily_api_key_here
